  {
   "default": "\u0906\u092a\u0915\u094b \u091f\u0940\u092e \u0932\u0940\u0921\u0930 \u0924\u094d\u0930\u0941\u091f\u093f (No Nearby Team Leader Error) \u092a\u094d\u0930\u093e\u092a\u094d\u0924 \u0939\u0941\u0908 \u0939\u0948. \u0915\u0943\u092a\u092f\u093e \u0928\u093f\u092e\u094d\u0928 \u0915\u093e\u0930\u094d\u092f \u0915\u0930\u0947\u0902: (1) \u092f\u0926\u093f \u0906\u092a \u092f\u093e\u0924\u094d\u0930\u093e \u0915\u0930 \u0930\u0939\u0947 \u0939\u0948\u0902, \u0924\u094b \u0910\u092a \u092e\u0947\u0902 \u092f\u093e\u0924\u094d\u0930\u093e \u0905\u0928\u0941\u092e\u0924\u093f \u0915\u0947 \u0932\u093f\u090f \u0905\u0928\u0941\u0930\u094b\u0927 \u0915\u0930\u0947\u0902 (Travel Request), \u091c\u094b \u0906\u092a\u0915\u0947 \u092c\u093f\u091c\u0928\u0947\u0938 \u0932\u093e\u0907\u0928 \u092e\u0948\u0928\u0947\u091c\u0930 \u0926\u094d\u0935\u093e\u0930\u093e \u0905\u0928\u0941\u092e\u094b\u0926\u093f\u0924 \u0939\u094b\u0928\u0947 \u092a\u0930 (Approval by Business Line Manager), \u0906\u092a\u0915\u094b \u091a\u0947\u0915 \u0907\u0928 \u0915\u0930\u0928\u0947 \u0915\u0940 \u0905\u0928\u0941\u092e\u0924\u093f \u0926\u0947\u0917\u093e\u0964 (2) \u092f\u0926\u093f \u0906\u092a \u0905\u092a\u0928\u0947 \u091f\u0940\u092e \u0932\u0940\u0921\u0930 \u0915\u0947 \u0938\u093e\u0925 \u0938\u093e\u0907\u091f \u092a\u0930 \u0939\u0948\u0902, \u0924\u094b \u0905\u092a\u0928\u0947 \u091f\u0940\u092e \u0932\u0940\u0921\u0930 \u0938\u0947 \u091a\u0947\u0915 \u0907\u0928 \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0915\u0939\u0947\u0902 \u0914\u0930 \u0909\u0938\u0915\u0947 \u092c\u093e\u0926 \u0906\u092a \u091a\u0947\u0915 \u0907\u0928 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964 \u092f\u0926\u093f \u091f\u0940\u092e \u0932\u0940\u0921\u0930 \u092a\u0939\u0932\u0947 \u0938\u0947 \u0939\u0940 \u091a\u0947\u0915 \u0907\u0928 \u0939\u0948, \u0924\u094b \u0909\u0938\u0947 \u0905\u092a\u0928\u093e \u0938\u094d\u0925\u093e\u0928 \u0905\u092a\u0921\u0947\u091f (Update Location) \u0915\u0930\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0915\u0939\u0947\u0902 \u0914\u0930 \u092b\u093f\u0930 \u0906\u092a \u091a\u0947\u0915 \u0907\u0928 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964 (3) \u092f\u0926\u093f \u0906\u092a\u0915\u093e \u091f\u0940\u092e \u0932\u0940\u0921\u0930 \u0938\u093e\u0907\u091f \u092a\u0930 \u0928\u0939\u0940\u0902 \u0939\u0948, \u0924\u094b \u0905\u092a\u0928\u0947 \u092c\u093f\u091c\u0928\u0947\u0938 \u0932\u093e\u0907\u0928 \u092e\u0948\u0928\u0947\u091c\u0930 \u0915\u094b \u0915\u093f\u0938\u0940 \u0914\u0930 \u0915\u094b \u0905\u0938\u094d\u0925\u093e\u092f\u0940 \u091f\u0940\u092e \u0932\u0940\u0921\u0930 \u092c\u0928\u093e\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0938\u0942\u091a\u093f\u0924 \u0915\u0930\u0947\u0902 \u0914\u0930 \u0909\u0938\u0915\u0947 \u092c\u093e\u0926 \u0906\u092a \u0938\u092d\u0940 \u091a\u0947\u0915 \u0907\u0928 \u0915\u0930 \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964 \u0915\u0943\u092a\u092f\u093e \u0927\u094d\u092f\u093e\u0928 \u0926\u0947\u0902 \u0915\u093f \u092f\u0926\u093f \u0906\u092a \u0909\u092a\u0930\u094b\u0915\u094d\u0924 \u092e\u0947\u0902 \u0938\u0947 \u0915\u093f\u0938\u0940 \u092d\u0940 \u0924\u0930\u0940\u0915\u0947 \u0938\u0947 \u091a\u0947\u0915-\u0907\u0928 \u0928\u0939\u0940\u0902 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902, \u0924\u094b \u0906\u092a\u0915\u094b \u091b\u0941\u091f\u094d\u091f\u0940 \u092a\u0930 \u092e\u093e\u0928\u093e \u091c\u093e\u090f\u0917\u093e\u0964",
